{
  "name": "nuxt-component-islands-demo",
  "private": true,
  "type": "module",
  "description": "A didactic Nuxt 4 proof-of-concept that teaches Nuxt component islands (server components) through a side-by-side comparison.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
